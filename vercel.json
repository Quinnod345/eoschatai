{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "eosbot.ai" }],
      "destination": "https://www.eosbot.ai/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/usage/daily",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/usage/monthly",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/grace-period-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/subscription-health-check",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron/circle-sync",
      "schedule": "0 2 * * *"
    }
  ]
}


