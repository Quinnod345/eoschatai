# =============================================================================
# EOSAI Environment Variables
# =============================================================================
# Copy this file to .env.local for local development
# All secrets should be kept secure and never committed to version control
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection URL - at least one is required
# POSTGRES_URL is preferred (Vercel/Neon naming convention)
POSTGRES_URL="postgresql://user:password@host:5432/database?sslmode=require"
# DATABASE_URL is a fallback (standard naming)
# DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Non-pooling URLs for migrations (optional, uses main URL if not set)
# POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/database?sslmode=require"
# DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/database?sslmode=require"

# -----------------------------------------------------------------------------
# AUTHENTICATION (Required)
# -----------------------------------------------------------------------------
# NextAuth.js secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Google OAuth credentials (required for Google sign-in)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# AI PROVIDERS (Required - at least Anthropic)
# -----------------------------------------------------------------------------
# Anthropic API key (required - primary AI provider)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api..."

# OpenAI API key (required for image generation, voice features, embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# AssemblyAI API key (optional - for voice recording analysis)
# Get from: https://www.assemblyai.com/
# ASSEMBLYAI_API_KEY="your-assemblyai-key"

# -----------------------------------------------------------------------------
# UPSTASH REDIS (Required for caching and rate limiting)
# -----------------------------------------------------------------------------
# Upstash Redis REST API credentials
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# Alternative Redis URL (for streaming features)
# REDIS_URL="redis://default:password@host:6379"

# -----------------------------------------------------------------------------
# UPSTASH VECTOR (Required for RAG/embeddings)
# -----------------------------------------------------------------------------
# Main vector store for EOS knowledge base
UPSTASH_VECTOR_REST_URL="https://your-vector.upstash.io"
UPSTASH_VECTOR_REST_TOKEN="your-vector-token"

# User RAG vector store (for user documents and course content)
UPSTASH_USER_RAG_REST_URL="https://your-user-rag.upstash.io"
UPSTASH_USER_RAG_REST_TOKEN="your-user-rag-token"

# -----------------------------------------------------------------------------
# STRIPE BILLING (Required for paid features)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Also available as:
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret for Stripe events
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs for subscription tiers
# Create these in Stripe Dashboard > Products
PRO_MONTHLY_PRICE_ID="price_..."
PRO_ANNUAL_PRICE_ID="price_..."
BUSINESS_SEAT_MONTHLY_PRICE_ID="price_..."
BUSINESS_SEAT_ANNUAL_PRICE_ID="price_..."

# -----------------------------------------------------------------------------
# EMAIL (Required for transactional emails)
# -----------------------------------------------------------------------------
# Resend API key
# Get from: https://resend.com/
RESEND_API_KEY="re_..."

# From address for emails (must be verified in Resend)
RESEND_FROM_ADDRESS="EOSAI <noreply@eosbot.ai>"
# Alternative: EMAIL_FROM="noreply@eosbot.ai"

# Webhook secret for Resend events (optional)
# RESEND_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# CIRCLE INTEGRATION (Optional - for course content)
# -----------------------------------------------------------------------------
# Circle.so API credentials for course sync
# CIRCLE_API_TOKEN="your-circle-api-token"
# CIRCLE_HEADLESS_AUTH_TOKEN="your-headless-token"
# CIRCLE_API_BASE_URL="https://app.circle.so/api/v1"
# CIRCLE_SPACE_ID="2310423"

# -----------------------------------------------------------------------------
# FIRECRAWL/WEB SEARCH (Optional - for deep research)
# -----------------------------------------------------------------------------
# Firecrawl API key for web scraping
# Get from: https://firecrawl.dev/
# FIRECRAWL_API_KEY="fc-..."

# Firesearch configuration
# FIRESEARCH_MAX_DEPTH="3"
# FIRESEARCH_MAX_SOURCES="20"
# FIRESEARCH_TIMEOUT="120000"
# FIRESEARCH_FOLLOWUP="true"
# FIRESEARCH_STREAMING="true"
# FIRESEARCH_RATE_LIMIT="10"
# FIRESEARCH_CONCURRENT="1"
# FIRESEARCH_CACHE_TTL="3600"

# -----------------------------------------------------------------------------
# SENTRY ERROR TRACKING (Recommended for production)
# -----------------------------------------------------------------------------
# Get from: https://sentry.io/
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
# SENTRY_ORG="your-org"
# SENTRY_PROJECT="eosai"

# -----------------------------------------------------------------------------
# APPLICATION URLS (Required)
# -----------------------------------------------------------------------------
# Public-facing app URL (used for OAuth callbacks, emails, etc.)
NEXT_PUBLIC_APP_URL="https://eosbot.ai"
# Alternative: APP_URL="https://eosbot.ai"

# Base URL for API calls (typically same as app URL)
NEXT_PUBLIC_BASE_URL="https://eosbot.ai"

# WebSocket URL (optional - for real-time features)
# NEXT_PUBLIC_WS_URL="wss://eosbot.ai"

# -----------------------------------------------------------------------------
# ACCESS CONTROL (Optional)
# -----------------------------------------------------------------------------
# Comma-separated list of admin email addresses
# ADMIN_EMAILS="admin@example.com,superuser@example.com"

# Implementer access control (comma-separated)
# IMPLEMENTER_ALLOWED_EMAILS="implementer@example.com"
# IMPLEMENTER_ALLOWED_DOMAINS="eosworldwide.com"

# -----------------------------------------------------------------------------
# CRON & INTERNAL APIS (Required for scheduled jobs)
# -----------------------------------------------------------------------------
# Secret for authenticating cron job requests (Vercel Cron)
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret"

# Internal API key for service-to-service calls
# INTERNAL_API_KEY="your-internal-api-key"

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features (true/false)
# FEATURE_FLAG_FREE_GATING_V1="true"
# FEATURE_FLAG_STRIPE_MVP="true"
# FEATURE_FLAG_ENTITLEMENTS_WS="true"

# -----------------------------------------------------------------------------
# DEBUG & DEVELOPMENT (Optional - NOT for production)
# -----------------------------------------------------------------------------
# Enable debug endpoints (never in production!)
# ALLOW_DEBUG_ENDPOINTS="false"

# Auto-fix subscription issues (use with caution)
# AUTO_FIX_SUBSCRIPTIONS="false"

# Suppress console logs
# SILENT_LOGS="false"

# Log level: debug, info, warn, error
# LOG_LEVEL="info"

# Meticulous testing bypass (for E2E tests)
# METICULOUS_AUTH_BYPASS_SECRET="test-secret"

# Vercel Blob storage (for file uploads)
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# -----------------------------------------------------------------------------
# VERCEL (Automatically set by Vercel)
# -----------------------------------------------------------------------------
# These are set automatically when deployed to Vercel:
# VERCEL_ENV="production" | "preview" | "development"
# VERCEL_PROJECT_PRODUCTION_URL="your-project.vercel.app"
# NODE_ENV="production" | "development"
