  "name": "ai-chatbot",
  "version": "3.0.19",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096\" next dev --turbo",
    "build": "tsx lib/db/migrate && NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "start": "next start",
    "lint": "next lint && biome lint --write --unsafe",
    "lint:fix": "next lint --fix && biome lint --write --unsafe",
    "format": "biome format --write",
    "check:sensitive-logs": "bash scripts/check-sensitive-logs.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push --accept-data-loss",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "db:auto-migrate": "node scripts/auto-migrate.js",
    "db:auto-migrate-conditional": "node scripts/auto-migrate-conditional.js",
    "db:run-migrations": "node scripts/run-migrations.js",
    "db:pgvector": "node scripts/migrate-pgvector.js",
    "db:add-profile-picture": "npx tsx scripts/run-migration.ts",
    "db:add-documents": "npx tsx scripts/run-document-migration.ts",
    "db:alter-documents": "npx tsx scripts/alter-userdocuments-filetype.ts",
    "db:create-documents": "npx tsx scripts/create-documents-table.ts",
    "setup:doc-features": "pnpm install xlsx",
    "test-blob": "npx tsx scripts/test-blob.ts",
    "test": "export PLAYWRIGHT=True && pnpm exec playwright test",
    "test:unit": "pnpm exec vitest run",
    "test:components": "pnpm exec vitest run --config vitest.component.config.ts",
    "db:seed": "tsx drizzle/seed.ts",
    "upload-docs": "tsx scripts/upload-documents.ts",
    "upload-knowledge": "tsx scripts/upload-system-knowledge.ts",
    "upload-eos-docs": "tsx scripts/upload-eos-implementer-docs.ts",
