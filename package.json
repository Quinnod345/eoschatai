    "reset-vector": "tsx scripts/reset-vector-store.ts",
    "migrate-user-rag": "tsx scripts/migrate-to-user-rag.ts",
    "redis:setup": "node scripts/add-redis-config.js",
    "redis:test": "node scripts/test-redis-connection.js",
    "fix-db-columns": "node scripts/fix-db-columns.js",
    "fix-manifests": "node scripts/fix-client-manifests.js",
    "render-pdf": "tsx scripts/render-markdown-pdf.ts",
    "seed:autocomplete": "tsx scripts/seed-autocomplete.ts"
